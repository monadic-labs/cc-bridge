{
  "name": "@monadic-labs/ccb",
  "version": "2.0.0",
  "type": "module",
  "description": "A local HTTP proxy for Claude Code to route requests to multiple providers.",
  "main": "src/proxy-core.js",
  "bin": {
    "ccb": "bin/ccb.js",
    "cc-bridge": "bin/ccb.js"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/setup-user-dir.js",
    "providers.example.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "proxy": "node src/proxy.js",
    "lint": "eslint src/ bin/",
    "test": "eslint src/ bin/ && node src/test.js",
    "test:browser": "playwright test --config=test/browser/playwright.config.js",
    "install-cmd": "npm install -g .",
    "kill": "node scripts/kill.js",
    "killall": "node scripts/kill.js all",
    "postinstall": "node scripts/setup-user-dir.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monadic-labs/cc-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/monadic-labs/cc-bridge/issues"
  },
  "homepage": "https://github.com/monadic-labs/cc-bridge#readme",
  "keywords": [
    "claude",
    "anthropic",
    "ai",
    "proxy",
    "gateway",
    "ccb"
  ],
  "author": "MarcTCruz",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "eslint": "^10.2.0",
    "node-pty": "^1.1.0"
  }
}
